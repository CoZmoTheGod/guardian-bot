# ============================================================================
# Guardian Bot — Environment Template
# ----------------------------------------------------------------------------
# Copy this file to the environment file matching your NODE_ENV:
#   Development : cp .env.example .env.dev        (NODE_ENV=development)
#   Production  : cp .env.example .env.production  (NODE_ENV=production)
# The loader (src/config.js) picks .env.dev when NODE_ENV=development,
# .env.production when NODE_ENV=production, otherwise plain .env.
# NEVER commit the filled-in files — they contain secrets.
# ============================================================================

# ---- Runtime ---------------------------------------------------------------
# development | production  (controls token/db/log behaviour & command scope)
NODE_ENV=development

# Verbose debug logging: prints command execution, DB queries and API results.
DEBUG=true

# Optional explicit log level: error | warn | info | debug (overrides DEBUG).
# LOG_LEVEL=debug

# ---- Discord ---------------------------------------------------------------
# Bot token from https://discord.com/developers/applications  (Bot -> Token).
# Use a SEPARATE application/token for development vs production.
DISCORD_TOKEN=your-bot-token-here

# Application (client) ID — used to register slash commands.
# Found under General Information -> Application ID. Optional (falls back to
# the logged-in bot's own ID at runtime), but required for `npm run deploy`.
CLIENT_ID=your-application-id-here

# Test guild (server) ID. In development, slash commands register INSTANTLY to
# this single guild. Leave blank in production to register commands globally.
GUILD_ID=your-test-guild-id-here

# ---- Database --------------------------------------------------------------
# SQLite (default, zero-config):  sqlite://./data/guardian.sqlite
# PostgreSQL:                     postgres://user:pass@host:5432/guardian
DATABASE_URL=sqlite://./data/guardian.sqlite

# ---- Music: YouTube --------------------------------------------------------
# YouTube Data API v3 key (used for search). Streaming works without it, but a
# key gives reliable search results and higher quota.
YOUTUBE_API_KEY=your-youtube-api-key-here

# ---- Music: Spotify --------------------------------------------------------
# Spotify app credentials (Client Credentials flow) used to resolve Spotify
# links/searches into track metadata, which is then streamed from YouTube.
# https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your-spotify-client-id-here
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret-here

# ---- Web Dashboard --------------------------------------------------------
# Optional Discord-OAuth-secured admin panel. Logged-in users see only the
# guilds where the bot is present AND they have Manage Server permission —
# so sharing the URL with someone else gives them access to *their* servers,
# not yours.
#
# Enable the panel:
DASHBOARD_ENABLED=true
# Port to listen on. Change if 3000 is taken (or you're running multiple bots).
DASHBOARD_PORT=3000
# Public URL used to build the OAuth redirect. Must EXACTLY match the redirect
# URI configured in the Discord Developer Portal (OAuth2 -> Redirects).
#   Dev :  http://localhost:3000
#   Prod:  https://guardian.example.com   (behind a reverse proxy / HTTPS)
DASHBOARD_URL=http://localhost:3000
# Random long string used to sign session cookies. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
DASHBOARD_SESSION_SECRET=change-me-to-a-long-random-string
# Discord application client secret (OAuth2 -> Client Secret). REQUIRED for
# the login flow. Do NOT share — it lets anyone act as your app.
DISCORD_CLIENT_SECRET=your-discord-client-secret-here
