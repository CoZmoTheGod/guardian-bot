<%- include('../partials/header') %>
<div class="dashboard-shell">
  <%- include('../partials/sidebar') %>
  <main class="content">
    <%- include('../partials/flashes') %>
    <h1>Welcome & Leave</h1>
    <p class="lead">
      Placeholders you can use anywhere: <code>{user}</code>, <code>{user.tag}</code>,
      <code>{user.name}</code>, <code>{server}</code>, <code>{memberCount}</code>.
    </p>

    <form method="post" action="/servers/<%= guild.id %>/welcome" class="settings-form">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">

      <section class="card">
        <h2>Welcome message</h2>
        <label class="field checkbox">
          <input type="checkbox" name="welcomeEnabled" <%= settings.welcomeEnabled ? 'checked' : '' %>>
          <span>Post a welcome message in a channel when a member joins</span>
        </label>
        <label class="field">
          <span>Welcome channel</span>
          <select name="welcomeChannelId">
            <option value="">— none —</option>
            <% channels.forEach(function (c) { %>
              <option value="<%= c.id %>" <%= settings.welcomeChannelId === c.id ? 'selected' : '' %>>
                <%= (c.parent ? c.parent + ' / ' : '') + '#' + c.name %>
              </option>
            <% }) %>
          </select>
        </label>
        <label class="field">
          <span>Welcome message</span>
          <textarea name="welcomeMessage" rows="3"><%= settings.welcomeMessage %></textarea>
        </label>
      </section>

      <section class="card">
        <h2>Welcome card (image)</h2>
        <p class="muted" style="margin:-4px 0 12px">
          A MEE6-style rendered image with the joining member's avatar and a member-count subtitle. Attached alongside the welcome message above.
        </p>
        <label class="field checkbox">
          <input type="checkbox" name="welcomeCardEnabled" <%= settings.welcomeCardEnabled ? 'checked' : '' %>>
          <span>Attach a rendered welcome card to the join message</span>
        </label>
        <label class="field">
          <span>Background image URL <small>(https recommended; leave blank for a gradient)</small></span>
          <input type="text" name="welcomeCardBackgroundUrl" value="<%= settings.welcomeCardBackgroundUrl || '' %>" placeholder="https://example.com/background.png">
        </label>
        <div class="grid-2">
          <label class="field">
            <span>Title text</span>
            <input type="text" name="welcomeCardTitle" value="<%= settings.welcomeCardTitle %>" maxlength="200">
            <small>Placeholders: <code>{user.name}</code>, <code>{server}</code>, <code>{memberCount}</code></small>
          </label>
          <label class="field">
            <span>Subtitle text</span>
            <input type="text" name="welcomeCardSubtitle" value="<%= settings.welcomeCardSubtitle %>" maxlength="200">
            <small>Placeholders: <code>{memberCount}</code>, <code>{user.name}</code>, <code>{server}</code></small>
          </label>
          <label class="field">
            <span>Title colour</span>
            <input type="color" name="welcomeCardTitleColor" value="<%= settings.welcomeCardTitleColor || '#ffffff' %>">
          </label>
          <label class="field">
            <span>Subtitle colour</span>
            <input type="color" name="welcomeCardSubtitleColor" value="<%= settings.welcomeCardSubtitleColor || '#cccccc' %>">
          </label>
          <label class="field">
            <span>Accent colour (ring + pill)</span>
            <input type="color" name="welcomeCardAccentColor" value="<%= settings.welcomeCardAccentColor || '#5865f2' %>">
          </label>
        </div>
        <div class="card-preview">
          <div class="card-preview-label">
            Live preview <small>(uses <em>saved</em> settings and <em>your</em> avatar — save your changes then refresh)</small>
          </div>
          <img
            src="/servers/<%= guild.id %>/welcome/card-preview.png?t=<%= Date.now() %>"
            alt="Welcome card preview"
            style="max-width:100%;border-radius:8px;display:block"
            onerror="this.style.display='none'; this.nextElementSibling.style.display='block'"
          >
          <div class="muted" style="display:none;padding:12px;text-align:center">
            Preview unavailable — the canvas renderer may be missing fonts. Card rendering still works when tested with a real join.
          </div>
        </div>
      </section>

      <section class="card">
        <h2>Leave message</h2>
        <label class="field checkbox">
          <input type="checkbox" name="leaveEnabled" <%= settings.leaveEnabled ? 'checked' : '' %>>
          <span>Post a message when a member leaves</span>
        </label>
        <label class="field">
          <span>Leave channel</span>
          <select name="leaveChannelId">
            <option value="">— none —</option>
            <% channels.forEach(function (c) { %>
              <option value="<%= c.id %>" <%= settings.leaveChannelId === c.id ? 'selected' : '' %>>
                <%= (c.parent ? c.parent + ' / ' : '') + '#' + c.name %>
              </option>
            <% }) %>
          </select>
        </label>
        <label class="field">
          <span>Leave message</span>
          <textarea name="leaveMessage" rows="3"><%= settings.leaveMessage %></textarea>
        </label>
      </section>

      <section class="card">
        <h2>Welcome DM</h2>
        <label class="field checkbox">
          <input type="checkbox" name="welcomeDmEnabled" <%= settings.welcomeDmEnabled ? 'checked' : '' %>>
          <span>Send a direct message to new members</span>
        </label>
        <label class="field">
          <span>DM message</span>
          <textarea name="welcomeDmMessage" rows="3"><%= settings.welcomeDmMessage %></textarea>
        </label>
      </section>

      <section class="card">
        <h2>Ghost-ping prevention</h2>
        <label class="field checkbox">
          <input type="checkbox" name="ghostPingPrevention" <%= settings.ghostPingPrevention ? 'checked' : '' %>>
          <span>Log deleted messages that mentioned members or roles</span>
        </label>
      </section>

      <div class="form-actions">
        <button type="submit" class="btn primary">Save changes</button>
      </div>
    </form>
  </main>
</div>
<%- include('../partials/footer') %>
