{
  "name": "guardian-bot",
  "version": "1.0.0",
  "description": "Guardian — All-in-One Discord bot: moderation, music, reaction roles, anti-bot captcha, server backup/restore and join/leave. discord.js v14.",
  "type": "commonjs",
  "main": "src/index.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node src/index.js",
    "dev": "cross-env NODE_ENV=development nodemon --watch src --ext js,json --exec \"node src/index.js\"",
    "deploy": "node src/deploy-commands.js",
    "deploy:global": "node src/deploy-commands.js --global",
    "db:sync": "node src/scripts/sync-db.js"
  },
  "keywords": [
    "discord",
    "discord.js",
    "moderation",
    "music",
    "reaction-roles",
    "captcha",
    "backup",
    "bot"
  ],
  "license": "MIT",
  "dependencies": {
    "@discordjs/opus": "^0.9.0",
    "@discordjs/voice": "^0.19.2",
    "@napi-rs/canvas": "^0.1.65",
    "discord.js": "^14.26.4",
    "dotenv": "^16.4.7",
    "ejs": "^6.0.1",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "ffmpeg-static": "^5.2.0",
    "libsodium-wrappers": "^0.7.15",
    "opusscript": "^0.0.8",
    "pg": "^8.13.1",
    "pg-hstore": "^2.3.4",
    "play-dl": "^1.9.7",
    "prism-media": "^1.3.5",
    "sequelize": "^6.37.5",
    "sponsorblock-api": "^0.2.4",
    "sqlite3": "^5.1.7",
    "youtube-dl-exec": "^3.1.8"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "nodemon": "^3.1.9"
  }
}
